# Croatian Price Comparison Data Preprocessing - Configuration
# Copy this file to .env and fill in your values
# cp env.example .env

# ==============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# ==============================================================================

# Path to directory containing raw store data (CSV files organized by market chain)
# This directory should contain subdirectories for each market chain (e.g., konzum/, spar/, etc.)
# Each subdirectory should have: stores.csv, products.csv, prices.csv
STORES_DIR_PATH=/path/to/raw/store/data

# Output directory for cleaned and processed data
# The tool will create this directory if it doesn't exist
OUTPUT_DATA_DIR=cleaned_data

# Directory where comparison reports will be saved (JSON and Markdown)
# The tool will create this directory if it doesn't exist
COMPARISON_REPORTS_OUTPUT_DIR=reports

# Path to cities mapping CSV file (format: from;to)
# This file maps city names from raw data to standardized names
# Example: Zagreb;Zagreb or Rijeka - centar;Rijeka
# Take a look at https://github.com/usporedicijene/mappings
CITIES_MAPPINGS_CSV=cities_mappings.csv

# Path to categories mapping CSV file (format: from;to)
# This file maps product categories from raw data to standardized names
# Categories ending with ~~ will be filtered out from prices
# Take a look at https://github.com/usporedicijene/mappings
CATEGORIES_MAPPINGS_CSV=categories_mappings.csv

# ==============================================================================
# OPTIONAL ENVIRONMENT VARIABLES
# ==============================================================================

# Path to cleaned anchor price data for price change calculations
# If provided, the tool will calculate price changes against this baseline
# If not set, only derived_price will be calculated (no price_change column)
# STORES_DIR_PATH_ANCHOR_CLEANED_DATA=/path/to/anchor/cleaned/data

# Path to previous day's cleaned data for comparison
# If provided, the tool will generate comparison reports showing:
# - New/missing stores
# - New/missing products  
# - Price changes
# If not set, comparison will be skipped
# STORES_DIR_PATH_PREVIOUS_DAY_CLEANED_DATA=/path/to/previous/day/cleaned/data

# ==============================================================================
# DEBUG OPTIONS
# ==============================================================================

# Uncomment to enable debug output for city validation
# This will print all reference cities and found cities for comparison
# DEBUG_CITIES=1

# ==============================================================================
# EXAMPLE CONFIGURATION
# ==============================================================================

# Example for local development:
# STORES_DIR_PATH=./raw_data
# OUTPUT_DATA_DIR=./cleaned_data
# COMPARISON_REPORTS_OUTPUT_DIR=./reports
# CITIES_MAPPINGS_CSV=./cities_mappings.csv
# CATEGORIES_MAPPINGS_CSV=./categories_mappings.csv
# STORES_DIR_PATH_ANCHOR_CLEANED_DATA=./anchor_data
# STORES_DIR_PATH_PREVIOUS_DAY_CLEANED_DATA=./previous_day_data

# Example for production:
# STORES_DIR_PATH=/data/raw/2024-11-09
# OUTPUT_DATA_DIR=/data/cleaned/2024-11-09
# COMPARISON_REPORTS_OUTPUT_DIR=/data/reports
# CITIES_MAPPINGS_CSV=/config/cities_mappings.csv
# CATEGORIES_MAPPINGS_CSV=/config/categories_mappings.csv
# STORES_DIR_PATH_ANCHOR_CLEANED_DATA=/data/cleaned/2024-09-08
# STORES_DIR_PATH_PREVIOUS_DAY_CLEANED_DATA=/data/cleaned/2024-11-08
